# Copy to .env.local for local testing (and add the same values in Vercel's dashboard).
# Get the service_role key from Supabase → Project Settings → API.

# Your project's API URL (already filled in — this value is not secret):
SUPABASE_URL=https://vohmgpexhexrgwmfctqp.supabase.co

# The SERVICE ROLE key (secret). Server-side only. Do NOT use the anon/publishable key here,
# and never expose this value in the browser or commit it to git.
# Find it: Supabase dashboard → Project Settings → API → Project API keys → "service_role" (click "Reveal").
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
